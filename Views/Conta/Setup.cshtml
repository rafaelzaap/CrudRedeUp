@model SetupAdminViewModel

@{
    ViewData["Title"] = "Criar administrador";
    Layout = "_AuthLayout";
}

<div class="auth-panel">
    <h1>Criar administrador</h1>
    <p>Configure o primeiro acesso antes de publicar o painel.</p>

    <form asp-action="Setup" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Nome" class="form-label"></label>
            <input asp-for="Nome" class="form-control" autocomplete="name" autofocus />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" autocomplete="username" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Senha" class="form-label"></label>
            <input asp-for="Senha" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Senha" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmarSenha" class="form-label"></label>
            <input asp-for="ConfirmarSenha" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
        </div>

        <button class="btn btn-primary w-100" type="submit">Criar administrador</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
