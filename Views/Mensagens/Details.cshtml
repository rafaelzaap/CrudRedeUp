@model Mensagem

@{
    ViewData["Title"] = "Detalhes da mensagem";
}

@if (TempData["Mensagem"] is string mensagem)
{
    <div class="alert alert-success" role="alert">@mensagem</div>
}

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger" role="alert">@erro</div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Titulo</h1>
        <p class="text-muted mb-0">Id @Model.Id</p>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
        <form asp-action="EnviarAtiva" method="post" data-form-envio-mensagem>
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button
                class="btn @(Model.EstaAtiva ? "btn-success" : "btn-secondary")"
                type="submit"
                disabled="@(!Model.EstaAtiva)"
                data-botao-envio
                data-texto-enviando="Enviando...">
                <span class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true" data-spinner-envio></span>
                <span data-texto-envio>Enviar</span>
            </button>
        </form>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Ocasiao</dt>
    <dd class="col-sm-9">@Model.Ocasiao</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.EstaAtiva ? "Ativa" : "Inativa")</dd>

    <dt class="col-sm-3">Criada em</dt>
    <dd class="col-sm-9">@(Model.CriadoEm?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

    <dt class="col-sm-3">Atualizada em</dt>
    <dd class="col-sm-9">@(Model.AtualizadoEm?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>

    <dt class="col-sm-3">Mensagem</dt>
    <dd class="col-sm-9">
        <div class="border rounded p-3 bg-light" style="white-space: pre-wrap;">@Model.Texto</div>
    </dd>
</dl>
