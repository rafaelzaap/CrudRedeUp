@model Mensagem

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<input type="hidden" asp-for="Id" />

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Titulo" class="form-label"></label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Ocasiao" class="form-label"></label>
        <input asp-for="Ocasiao" class="form-control" placeholder="Culto, aniversario, evento..." />
        <span asp-validation-for="Ocasiao" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="Ativo" class="form-label"></label>
        <select asp-for="Ativo" class="form-select">
            <option value="1">Ativa</option>
            <option value="0">Inativa</option>
        </select>
        <span asp-validation-for="Ativo" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Texto" class="form-label"></label>
        <textarea asp-for="Texto" class="form-control" rows="8"></textarea>
        <span asp-validation-for="Texto" class="text-danger"></span>
    </div>
</div>
