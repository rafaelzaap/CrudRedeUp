@model IReadOnlyList<Mensagem>

@{
    ViewData["Title"] = "Mensagens";
    var busca = ViewData["Busca"] as string;
    var incluirInativas = (bool)(ViewData["IncluirInativas"] ?? false);
    var envios = ViewData["Envios"] as IReadOnlyList<EnvioMensagemJob> ?? Array.Empty<EnvioMensagemJob>();
    var historico = ViewData["Historico"] as IReadOnlyList<EnvioMensagemHistorico> ?? Array.Empty<EnvioMensagemHistorico>();
    var atualizarAutomaticamente = envios.Any(e => e.Status is "Pendente" or "Processando");
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Mensagens</h1>
        <p class="text-muted mb-0">Cadastro das mensagens usadas no fluxo do n8n.</p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <form asp-action="EnviarAtiva" method="post" data-form-envio-mensagem>
            @Html.AntiForgeryToken()
            <button class="btn btn-success" type="submit" data-botao-envio data-texto-enviando="Enviando...">
                <span class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true" data-spinner-envio></span>
                <span data-texto-envio>Enviar mensagens ativas</span>
            </button>
        </form>
        <a class="btn btn-primary" asp-action="Create">Nova mensagem</a>
    </div>
</div>

@if (TempData["Mensagem"] is string mensagem)
{
    <div class="alert alert-success" role="alert">@mensagem</div>
}

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger" role="alert">@erro</div>
}

@if (TempData["DetalhesErro"] is string detalhesErro)
{
    <div class="alert alert-warning" role="alert" style="white-space: pre-wrap;">@detalhesErro</div>
}

@if (envios.Count > 0)
{
    <div class="mb-4">
        <h2 class="h5 mb-2">Envios em andamento</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Envio</th>
                        <th>Status</th>
                        <th>Inicio</th>
                        <th>Progresso</th>
                        <th>Resultado</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var envio in envios)
                {
                    <tr>
                        <td>@envio.Descricao</td>
                        <td>@envio.Status</td>
                        <td>@envio.IniciadoEm?.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td style="min-width: 260px;">
                            <div class="progress envio-progress" role="progressbar" aria-valuenow="@envio.Percentual" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width: @envio.Percentual%;">@envio.Percentual%</div>
                            </div>
                            <div class="small text-muted mt-1">
                                @if (envio.TotalItens > 0)
                                {
                                    <span>@envio.ItensProcessados/@envio.TotalItens</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(envio.ItemAtual))
                                {
                                    <span> - @envio.ItemAtual</span>
                                }
                            </div>
                        </td>
                        <td>
                            @if (envio.Resultado is not null)
                            {
                                <span>@envio.Resultado.TotalEnviados envio(s), @envio.Resultado.TotalErros erro(s)</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(envio.Erro))
                            {
                                <span class="text-danger">@envio.Erro</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

@if (historico.Count > 0)
{
    <div class="mb-4">
        <h2 class="h5 mb-2">Historico recente</h2>
        <div class="table-responsive historico-scroll">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Mensagem</th>
                        <th>Membro</th>
                        <th>Telefone</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in historico)
                {
                    <tr>
                        <td>@item.CriadoEm.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@item.MensagemId</td>
                        <td>@item.MembroNome</td>
                        <td>@item.TelefoneNormalizado</td>
                        <td>
                            <span>@item.Status</span>
                            @if (!string.IsNullOrWhiteSpace(item.Erro))
                            {
                                <div class="small text-danger">@item.Erro</div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-7">
        <label for="busca" class="form-label">Buscar</label>
        <input id="busca" name="busca" value="@busca" class="form-control" placeholder="Titulo, ocasiao ou mensagem" />
    </div>

    <div class="col-md-3">
        <div class="form-check mt-4">
            <input id="incluirInativas" name="incluirInativas" value="true" class="form-check-input" type="checkbox" checked="@incluirInativas" />
            <label class="form-check-label" for="incluirInativas">Incluir inativas</label>
        </div>
    </div>

    <div class="col-md-2 d-grid">
        <button class="btn btn-outline-secondary" type="submit">Filtrar</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titulo</th>
                <th>Ocasiao</th>
                <th>Status</th>
                <th>Criada em</th>
                <th class="text-end">Acoes</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">Nenhuma mensagem encontrada.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>
                        <div class="fw-semibold">@item.Titulo</div>
                        <div class="small text-muted text-truncate" style="max-width: 360px;">@item.Texto</div>
                    </td>
                    <td>@item.Ocasiao</td>
                    <td>
                        @if (item.EstaAtiva)
                        {
                            <span class="badge text-bg-success">Ativa</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Inativa</span>
                        }
                    </td>
                    <td>@(item.CriadoEm?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group" aria-label="Acoes da mensagem">
                            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Ver</a>
                            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Inativar</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@if (atualizarAutomaticamente)
{
    <script>
        window.setTimeout(() => window.location.reload(), 3000);
    </script>
}
