@model IReadOnlyList<AniversarianteViewModel>

@{
    ViewData["Title"] = "Aniversariantes";
    var historico = ViewData["Historico"] as IReadOnlyList<AniversarioEnvioHistorico> ?? Array.Empty<AniversarioEnvioHistorico>();
    var envioAutomaticoAtivo = (bool)(ViewData["EnvioAutomaticoAtivo"] ?? false);
    var existeAniversarianteHoje = (bool)(ViewData["ExisteAniversarianteHoje"] ?? false);
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Aniversariantes</h1>
        <p class="text-muted mb-0">Proximos aniversarios dos membros ativos nos proximos 3 meses.</p>
    </div>

    <div class="d-flex flex-wrap align-items-center justify-content-end gap-3">
        <form asp-action="AlternarAutomatico" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ativo" value="@(!envioAutomaticoAtivo)" />
            <button class="btn @(envioAutomaticoAtivo ? "btn-success" : "btn-outline-secondary")" type="submit">
                Automatico 09:00: @(envioAutomaticoAtivo ? "Ligado" : "Desligado")
            </button>
        </form>
        <form asp-action="EnviarAutomaticoHoje" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <button class="btn btn-primary" type="submit" disabled="@(!existeAniversarianteHoje)">
                Envio manual de hoje
            </button>
        </form>
    </div>
</div>

@if (TempData["Mensagem"] is string mensagem)
{
    <div class="alert alert-success" role="alert">@mensagem</div>
}

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger" role="alert">@erro</div>
}

@if (TempData["DetalhesErro"] is string detalhesErro)
{
    <div class="alert alert-warning" role="alert" style="white-space: pre-wrap;">@detalhesErro</div>
}

<div class="table-responsive mb-4">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Data</th>
                <th>Nome</th>
                <th>Telefone</th>
                <th>Faltam</th>
                <th>Nova idade</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">Nenhum aniversariante nos proximos 3 meses.</td>
            </tr>
        }
        else
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProximoAniversario.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="fw-semibold">@item.Nome</div>
                        <div class="small text-muted">Codigo @item.Codigo</div>
                    </td>
                    <td>@(item.Telefone ?? "-")</td>
                    <td>
                        @if (item.DiasRestantes == 0)
                        {
                            <span class="badge text-bg-success">Hoje</span>
                        }
                        else
                        {
                            <span>@item.DiasRestantes dia(s)</span>
                        }
                    </td>
                    <td>@item.IdadeNova</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@if (historico.Count > 0)
{
    <div class="mb-4">
        <h2 class="h5 mb-2">Historico de aniversarios</h2>
        <div class="table-responsive historico-scroll">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Membro</th>
                        <th>Tipo</th>
                        <th>Destino</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in historico)
                {
                    <tr>
                        <td>@item.CriadoEm.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@item.MembroCodigo</td>
                        <td>@item.Tipo</td>
                        <td>@item.TelefoneDestino</td>
                        <td>
                            <span>@item.Status</span>
                            @if (!string.IsNullOrWhiteSpace(item.Erro))
                            {
                                <div class="small text-danger">@item.Erro</div>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
