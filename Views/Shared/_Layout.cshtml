<!DOCTYPE html>
@inject EvolutionSender.Services.ISistemaStatusService SistemaStatusService
@{
    var sistemaStatus = await SistemaStatusService.VerificarAsync();
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EvolutionSender</title>
    <script type="importmap"></script>
    <script>
        (() => {
            const temaSalvo = localStorage.getItem('evolution-theme') || 'dark';
            document.documentElement.dataset.theme = temaSalvo;
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EvolutionSender.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Rafael_Developer</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Membros" asp-action="Index">Membros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Mensagens" asp-action="Index">Mensagens</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Aniversariantes" asp-action="Index">Aniversariantes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        <span class="small text-muted">@User.Identity?.Name</span>
                        <form asp-controller="Conta" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-secondary btn-sm" type="submit">Sair</button>
                        </form>
                    </div>
                    <button class="theme-toggle" type="button" aria-label="Alternar tema" title="Alternar tema" data-theme-toggle>
                        <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M21 14.7A8.3 8.3 0 0 1 9.3 3a7 7 0 1 0 11.7 11.7Z" />
                        </svg>
                        <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="4" />
                            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
                        </svg>
                    </button>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (!sistemaStatus.TudoOnline)
            {
                <div class="alert alert-warning border-0 shadow-sm" role="alert">
                    <div class="fw-semibold mb-1">Atenção: serviço indisponível</div>
                    @if (!sistemaStatus.BancoOnline)
                    {
                        <div>@sistemaStatus.ErroBanco</div>
                    }
                    @if (!sistemaStatus.EvolutionOnline)
                    {
                        <div>@sistemaStatus.ErroEvolution</div>
                    }
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - EvolutionSender - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
