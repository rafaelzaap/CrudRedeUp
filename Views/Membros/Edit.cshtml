@model Membro

@{
    ViewData["Title"] = "Editar membro";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Editar membro</h1>
    <p class="text-muted mb-0">@Model.Nome</p>
</div>

<form asp-action="Edit" asp-route-id="@Model.Codigo" method="post">
    @await Html.PartialAsync("_Form", Model)

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Salvar</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Codigo">Cancelar</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
