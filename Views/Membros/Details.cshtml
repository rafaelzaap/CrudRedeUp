@model Membro

@{
    ViewData["Title"] = "Detalhes do membro";
}

@if (TempData["Mensagem"] is string mensagem)
{
    <div class="alert alert-success" role="alert">@mensagem</div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Nome</h1>
        <p class="text-muted mb-0">Codigo @Model.Codigo</p>
    </div>

    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Voltar</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Codigo">Editar</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Primeiro nome</dt>
    <dd class="col-sm-9">@Model.PrimeiroNome</dd>

    <dt class="col-sm-3">Data de nascimento</dt>
    <dd class="col-sm-9">@Model.DataDeNascimento.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Telefone</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Telefone) ? "-" : Model.Telefone)</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@(Model.EstaAtivo ? "Ativo" : "Inativo")</dd>

    <dt class="col-sm-3">Observacao</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Observacao) ? "-" : Model.Observacao)</dd>
</dl>
