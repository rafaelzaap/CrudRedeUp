@model IReadOnlyList<Membro>

@{
    ViewData["Title"] = "Membros";
    var busca = ViewData["Busca"] as string;
    var incluirInativos = (bool)(ViewData["IncluirInativos"] ?? false);
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Membros</h1>
        <p class="text-muted mb-0">Cadastro e acompanhamento dos jovens da RedeUp.</p>
    </div>

    <a class="btn btn-primary" asp-action="Create">Novo membro</a>
</div>

@if (TempData["Mensagem"] is string mensagem)
{
    <div class="alert alert-success" role="alert">@mensagem</div>
}

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-7">
        <label for="busca" class="form-label">Buscar</label>
        <input id="busca" name="busca" value="@busca" class="form-control" placeholder="Nome, primeiro nome ou telefone" />
    </div>

    <div class="col-md-3">
        <div class="form-check mt-4">
            <input id="incluirInativos" name="incluirInativos" value="true" class="form-check-input" type="checkbox" checked="@incluirInativos" />
            <label class="form-check-label" for="incluirInativos">Incluir inativos</label>
        </div>
    </div>

    <div class="col-md-2 d-grid">
        <button class="btn btn-outline-secondary" type="submit">Filtrar</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Codigo</th>
                <th>Nome</th>
                <th>Nascimento</th>
                <th>Telefone</th>
                <th>Status</th>
                <th class="text-end">Acoes</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center text-muted py-4">Nenhum membro encontrado.</td>
            </tr>
        }
        else
        {
            foreach (var membro in Model)
            {
                <tr>
                    <td>@membro.Codigo</td>
                    <td>
                        <div class="fw-semibold">@membro.Nome</div>
                        <div class="small text-muted">@membro.PrimeiroNome</div>
                    </td>
                    <td>@membro.DataDeNascimento.ToString("dd/MM/yyyy")</td>
                    <td>@membro.Telefone</td>
                    <td>
                        @if (membro.EstaAtivo)
                        {
                            <span class="badge text-bg-success">Ativo</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Inativo</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group" aria-label="Acoes do membro">
                            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@membro.Codigo">Ver</a>
                            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@membro.Codigo">Editar</a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@membro.Codigo">Inativar</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
